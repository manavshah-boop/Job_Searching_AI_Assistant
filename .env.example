# Copy this file to .env and fill in your keys.
# Only the key for your active provider (set in config.yaml > llm.provider) is required.

ANTHROPIC_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Optional — enables dynamic company discovery via TheirStack.
# Without this key, the scraper uses only the priority list in config.yaml.
THEIRSTACK_API_KEY=your_key_here
