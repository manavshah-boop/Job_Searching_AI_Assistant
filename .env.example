# Copy this file to .env and fill in your keys.
# Only the key for your active provider (set in config.yaml > llm.provider) is required.
#
# On the Ubuntu deployment this file lives at:
#   /home/ubuntu/job-agent/.env
# It is loaded by both the Streamlit UI service (jobagent-ui@.service)
# and the daily worker service (jobagent-worker@.service) via EnvironmentFile=.

# ── LLM provider keys ─────────────────────────────────────────────────────────
# Per-profile keys (preferred) — suffix with uppercase profile slug:
# GROQ_API_KEY_MANAV=...
# GROQ_API_KEY_SISTER=...
#
# Unsuffixed keys are kept as a fallback for single-user / CLI use:
GROQ_API_KEY=your_key_here          # provider: "groq"      (free tier, recommended)
ANTHROPIC_API_KEY=your_key_here     # provider: "anthropic" (paid, best accuracy)
GEMINI_API_KEY=your_key_here        # provider: "gemini"    (free tier)
OPENAI_API_KEY=your_key_here        # provider: "openai"    (paid)

# ── Company discovery (optional) ─────────────────────────────────────────────
# Enables dynamic company discovery via TheirStack API.
# Without this key, the scraper uses only the priority list in config.yaml.
THEIRSTACK_API_KEY=your_key_here
